{
  "name": "clui",
  "version": "0.1.9",
  "description": "Clui - Desktop UI for Claude Code",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Youssef2430/clui.git"
  },
  "bugs": {
    "url": "https://github.com/Youssef2430/clui/issues"
  },
  "homepage": "https://github.com/Youssef2430/clui#readme",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "unset ELECTRON_RUN_AS_NODE && electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "electron-vite build --mode production && electron-builder --mac --dir",
    "dist:dmg": "electron-vite build --mode production && electron-builder --mac",
    "doctor": "bash scripts/doctor.sh",
    "postinstall": "electron-builder install-app-deps && bash scripts/patch-dev-icon.sh"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.35.1",
    "katex": "^0.16.43",
    "node-pty": "^1.1.0",
    "react-markdown": "^9.0.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "zustand": "^5.0.0"
  },
  "build": {
    "appId": "com.clui.app",
    "productName": "Clui",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/main/**/*",
      "dist/preload/**/*",
      "dist/renderer/**/*",
      "resources/**/*",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "Youssef2430",
      "repo": "clui"
    },
    "mac": {
      "icon": "resources/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Clui uses your microphone to transcribe voice input locally with Whisper."
      }
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.0.0",
    "postcss": "^8.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
